generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// npx prisma db push to push the schema to the database

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  phone        String        
  createdAt    DateTime      @default(now())
  reservations Reservation[]

  @@map("users")
}

model Prestation {
  id           String        @id @default(uuid())
  name         String
  price        Int
  duration     Int
  createdAt    DateTime      @default(now())
  reservations Reservation[]

  @@map("prestations")
}

model Reservation {
  id           String   @id @default(uuid())
  date         DateTime
  userId     String
  prestationId String
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  prestation Prestation @relation(fields: [prestationId], references: [id])

  @@map("reservations")
}
